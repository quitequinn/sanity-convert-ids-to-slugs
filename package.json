{
	"name": "@liiift-studio/sanity-convert-ids-to-slugs",
	"version": "2.0.0",
	"description": "Convert document IDs to slug-based IDs in Sanity Studio with automatic reference updating",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "esbuild src/index.jsx --bundle=true --format=esm --jsx=automatic --external:react --external:react-dom --external:sanity --external:@sanity/* --outfile=dist/index.js",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"sanity",
		"sanity-studio",
		"sanity-plugin",
		"slug",
		"id-conversion",
		"batch-processing",
		"content-management",
		"cms",
		"utility",
		"developer-tools"
	],
	"author": "Quinn Keaveney <hello@liiift.studio>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Liiift-Studio/sanity-convert-ids-to-slugs.git"
	},
	"bugs": {
		"url": "https://github.com/Liiift-Studio/sanity-convert-ids-to-slugs/issues"
	},
	"homepage": "https://github.com/Liiift-Studio/sanity-convert-ids-to-slugs#readme",
	"peerDependencies": {
		"@sanity/icons": "^2.0.0 || ^3.0.0",
		"@sanity/ui": "^1.0.0 || ^2.0.0 || ^3.0.0",
		"react": "^18.0.0 || ^19.0.0",
		"sanity": "^3.0.0 || ^4.0.0 || ^5.0.0"
	},
	"devDependencies": {
		"esbuild": "^0.25.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
